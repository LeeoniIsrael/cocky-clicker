<?xml version="1.0" encoding="utf-8"?>
<!--
  "CC" monogram in gold (#D4A843) on transparent background.
  Designed to sit on the garnet adaptive-icon background layer.
  Each letter is a bold C-bracket shape; second C is horizontally
  mirrored and offset to sit beside the first.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left  C  (x: 6 → 46, y: 22 → 86) -->
    <path
        android:fillColor="#D4A843"
        android:pathData="
          M6,22 L46,22 L46,34 L18,34 L18,74 L46,74 L46,86 L6,86 Z"/>

    <!-- Right C  (x: 52 → 102, y: 22 → 86) -->
    <path
        android:fillColor="#D4A843"
        android:pathData="
          M52,22 L102,22 L102,34 L64,34 L64,74 L102,74 L102,86 L52,86 Z"/>

    <!-- Small rooster comb above left C -->
    <path
        android:fillColor="#D4A843"
        android:pathData="
          M22,22 L25,14 L28,22
          M28,22 L31,12 L34,22
          M34,22 L37,16 L40,22"/>

</vector>
